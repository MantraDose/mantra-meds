# Supabase (required for auth)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: for synced inventory products store and cron (do not expose to client)
SUPABASE_SERVICE_ROLE_KEY=
# Cron: secret for /api/cron/sync-inventory-products (Vercel sends as Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Zoho (optional; for Products page from Zoho Inventory)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Must match the redirect URI used when generating the refresh token
ZOHO_REDIRECT_URI=http://localhost:3000
# Optional: for EU/IN/etc. use https://www.zohoapis.eu, https://www.zohoapis.in, etc.
# ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
# ZOHO_INVENTORY_BASE=https://www.zohoapis.com
# Optional: if you have multiple organizations
# ZOHO_INVENTORY_ORGANIZATION_ID=
